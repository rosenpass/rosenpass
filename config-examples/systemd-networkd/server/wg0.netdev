[NetDev]
Name=wg0
Kind=wireguard
Description=WireGuard tunnel managed by Rosenpass (server)

[WireGuard]
# IMPORTANT: No PresharedKey here! Rosenpass handles PSK rotation automatically.
ListenPort=9999
PrivateKeyFile=/etc/rosenpass/wg0/wg-server.key

[WireGuardPeer]
# Client peer public key
PublicKey=CLIENT_WG_PUBLIC_KEY_HERE
AllowedIPs=10.0.0.2/32
# No PresharedKey entry - Rosenpass manages this dynamically